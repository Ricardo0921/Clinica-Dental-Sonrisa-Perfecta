---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-CR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Related posts: other posts excluding current
const allPosts = (await getCollection('blog'))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title={`${post.data.title} | Blog — Sonrisa Perfecta`}
  description={post.data.description}
>
  <!-- POST HERO -->
  <section class="post-hero">
    <div class="post-hero-image" aria-hidden="true">
      <span>
        {post.slug.includes('esmalte') ? '🦷' :
         post.slug.includes('bracket') ? '😬' : '🔬'}
      </span>
    </div>
    <div class="post-hero-overlay">
      <div class="container">
        <a href="/blog" class="back-link">← Volver al blog</a>
        <div class="post-meta-hero">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <span>Por {post.data.author}</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </div>
    </div>
  </section>

  <!-- POST CONTENT -->
  <section class="post-layout">
    <div class="container post-grid">

      <!-- ARTICLE -->
      <article class="post-content prose">
        <Content />
      </article>

      <!-- SIDEBAR -->
      <aside class="post-sidebar">
        <div class="sidebar-card author-card">
          <div class="author-avatar-lg" aria-hidden="true">
            {post.slug.includes('implantes') ? '👨‍⚕️' :
             post.slug.includes('bracket') ? '👩‍⚕️' : '👨‍⚕️'}
          </div>
          <div>
            <strong>{post.data.author}</strong>
            <p>
              {post.slug.includes('implantes')
                ? 'Especialista en Implantología y Cirugía Oral · Clínica Dental Sonrisa Perfecta'
                : post.slug.includes('bracket')
                ? 'Especialista en Ortodoncia y Ortopedia Maxilar · Clínica Dental Sonrisa Perfecta'
                : 'Director Médico · Clínica Dental Sonrisa Perfecta'}
            </p>
          </div>
        </div>

        <div class="sidebar-card cta-card">
          <h3>¿Listo para actuar?</h3>
          <p>Agenda una consulta con nuestros especialistas. Primera visita sin costo.</p>
          <a href="tel:+50622345678" class="btn btn-primary w-full">📞 Llamar ahora</a>
          <a href="https://wa.me/50688887777" rel="noopener noreferrer" class="btn btn-whatsapp w-full">
            💬 WhatsApp
          </a>
        </div>

        {allPosts.length > 0 && (
          <div class="sidebar-card">
            <h3>Otros artículos</h3>
            <div class="related-posts">
              {allPosts.map((rp) => (
                <a href={`/blog/${rp.slug}`} class="related-post">
                  <span class="rp-icon">
                    {rp.slug.includes('esmalte') ? '🦷' :
                     rp.slug.includes('bracket') ? '😬' : '🔬'}
                  </span>
                  <div>
                    <strong>{rp.data.title}</strong>
                    <time datetime={rp.data.pubDate.toISOString()}>
                      {formatDate(rp.data.pubDate)}
                    </time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .post-hero {
    position: relative;
    min-height: 380px;
    display: flex;
    align-items: flex-end;
  }

  .post-hero-image {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0f2347 0%, #1B3A6B 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8rem;
    opacity: .25;
    user-select: none;
  }

  .post-hero-overlay {
    position: relative;
    z-index: 1;
    width: 100%;
    background: linear-gradient(to top, rgba(15,35,71,.95) 0%, rgba(15,35,71,.6) 100%);
    padding: 5rem 0 3rem;
    color: #fff;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,.7);
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color .15s;
  }

  .back-link:hover { color: #fff; }

  .post-meta-hero {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,.6);
    margin-bottom: 0.75rem;
  }

  .post-meta-hero span { padding-left: 1rem; border-left: 1px solid rgba(255,255,255,.25); }

  .post-hero h1 {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    max-width: 780px;
    margin-bottom: 0.85rem;
  }

  .post-description {
    font-size: 1rem;
    color: rgba(255,255,255,.75);
    max-width: 620px;
    line-height: 1.65;
  }

  /* LAYOUT */
  .post-layout { padding: 3.5rem 0 5rem; }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: flex-start;
  }

  /* PROSE — article typography */
  .prose {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    min-width: 0;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--navy);
    margin: 2.25rem 0 0.85rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--blue-light);
  }

  .prose :global(h2:first-child) { margin-top: 0; }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
    margin: 1.75rem 0 0.6rem;
  }

  .prose :global(p) {
    color: #374151;
    line-height: 1.8;
    margin-bottom: 1.1rem;
    font-size: 0.975rem;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }

  .prose :global(li) {
    color: #374151;
    line-height: 1.75;
    font-size: 0.975rem;
    margin-bottom: 0.3rem;
  }

  .prose :global(strong) {
    color: var(--navy);
    font-weight: 700;
  }

  .prose :global(em) { color: #4b5563; }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--blue-light);
    margin: 2rem 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--blue);
    background: var(--blue-light);
    padding: 1rem 1.5rem;
    border-radius: 0 8px 8px 0;
    margin: 1.5rem 0;
  }

  /* SIDEBAR */
  .post-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 88px;
  }

  .sidebar-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .sidebar-card h3 {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 1rem;
    color: var(--navy);
  }

  /* Author */
  .author-card { display: flex; align-items: flex-start; gap: 0.85rem; }

  .author-avatar-lg {
    font-size: 2.5rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--blue-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-card strong { display: block; font-size: 0.9rem; color: var(--navy); margin-bottom: .3rem; }
  .author-card p { font-size: 0.78rem; color: var(--muted); line-height: 1.5; }

  /* CTA */
  .cta-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .cta-card h3 { margin-bottom: 0; }
  .cta-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.5; margin: 0; }

  .w-full { width: 100%; }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    background: #25D366;
    color: #fff;
    border: none;
    transition: background .15s;
  }

  .btn-whatsapp:hover { background: #1da851; }

  /* Related posts */
  .related-posts { display: flex; flex-direction: column; gap: 1rem; }

  .related-post {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    text-decoration: none;
    transition: opacity .15s;
  }

  .related-post:hover { opacity: .75; }

  .rp-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--blue-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .related-post strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.35;
    margin-bottom: .2rem;
  }

  .related-post time {
    font-size: 0.72rem;
    color: var(--muted);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .post-grid {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
    }

    .prose {
      padding: 1.75rem;
    }
  }

  @media (max-width: 560px) {
    .prose {
      padding: 1.25rem;
    }
  }
</style>

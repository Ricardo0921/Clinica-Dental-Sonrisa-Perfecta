---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://sonrisaperfecta.cr');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="Sonrisa Perfecta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon (emoji SVG) -->
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🦷</text></svg>"
    />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <title>{title}</title>

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy:      #1B3A6B;
        --blue:      #4A90D9;
        --blue-light:#eef3fb;
        --text:      #1f2937;
        --muted:     #6b7280;
        --bg:        #ffffff;
        --border:    #e5e7eb;
        --radius:    12px;
        --shadow:    0 4px 24px rgba(27,58,107,.10);
        --shadow-lg: 0 8px 40px rgba(27,58,107,.16);
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        font-size: 1rem;
        line-height: 1.65;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a { color: inherit; }

      h1, h2, h3, h4 {
        line-height: 1.2;
        color: var(--navy);
      }

      /* ─── Utilities ────────────────────────── */
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      .section { padding: 5rem 0; }

      .section-header {
        text-align: center;
        margin-bottom: 3rem;
      }

      .section-header h2 {
        font-size: clamp(1.75rem, 4vw, 2.4rem);
        font-weight: 800;
        margin-bottom: 0.6rem;
      }

      .section-header p {
        font-size: 1.05rem;
        color: var(--muted);
        max-width: 560px;
        margin: 0 auto;
      }

      .badge {
        display: inline-block;
        background: var(--blue-light);
        color: var(--blue);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        padding: .28rem .85rem;
        border-radius: 100px;
        margin-bottom: .6rem;
      }

      /* ─── Buttons ──────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: .78rem 1.75rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background .15s, box-shadow .15s, transform .1s;
        line-height: 1;
      }

      .btn:active { transform: translateY(1px); }

      .btn-primary { background: var(--navy); color: #fff; }
      .btn-primary:hover { background: var(--blue); box-shadow: 0 4px 16px rgba(74,144,217,.4); }

      .btn-secondary {
        background: transparent;
        color: var(--navy);
        border: 2px solid var(--navy);
      }
      .btn-secondary:hover { background: var(--navy); color: #fff; }

      .btn-accent { background: var(--blue); color: #fff; }
      .btn-accent:hover { background: #2d78c8; box-shadow: 0 4px 16px rgba(74,144,217,.4); }

      .btn-lg { padding: 1rem 2.25rem; font-size: 1.05rem; }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

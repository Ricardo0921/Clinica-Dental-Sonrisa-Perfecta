        <li>
          <span class="icon">📍</span>
          <span>Barrio Escalante, Calle 33, San José, Costa Rica</span>
        </li>
        <li>
          <span class="icon">📞</span>
          <a href="tel:+50622345678">+506 2234-5678</a>
        </li>
        <li>
          <span class="icon">📱</span>
          <a href="https://wa.me/50688887777" rel="noopener noreferrer">+506 8888-7777 (WhatsApp)</a>
        </li>
        <li>
          <span class="icon">✉️</span>
          <a href="mailto:info@sonrisaperfecta.cr">info@sonrisaperfecta.cr</a>
        </li>
      </ul>
    </div>

    <!-- Horario -->
    <div class="footer-col">
      <h3>Horario de atención</h3>
      <ul class="schedule">
        <li><span>Lunes – Viernes</span><span>8:00 am – 6:00 pm</span></li>
        <li><span>Sábados</span><span>8:00 am – 12:00 pm</span></li>
        <li class="closed"><span>Domingos y feriados</span><span>Cerrado</span></li>
      </ul>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h3>Servicios</h3>
      <ul class="services-list">
        <li><a href="/#servicios">Limpieza dental</a></li>
        <li><a href="/#servicios">Ortodoncia y brackets</a></li>
        <li><a href="/#servicios">Implantes dentales</a></li>
        <li><a href="/#servicios">Blanqueamiento</a></li>
        <li><a href="/#servicios">Carillas de porcelana</a></li>
        <li><a href="/#servicios">Tratamiento de conductos</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {year} Clínica Dental Sonrisa Perfecta. Todos los derechos reservados.</p>
      <p>Diseñado con ❤️ en Costa Rica</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0f2347;
    color: #c8d8ee;
    margin-top: 4rem;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding: 3.5rem 1.25rem 2.5rem;
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: #fff;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .footer-brand p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #a0b4ce;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(74,144,217,0.15);
    color: #4A90D9;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .social-links a:hover {
    background: #4A90D9;
    color: #fff;
  }

  /* Cols */
  .footer-col h3 {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #a0b4ce;
  }

  .icon {
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .footer-col a {
    color: #a0b4ce;
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: #4A90D9;
  }

  /* Schedule */
  .schedule li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .schedule li:last-child {
    border-bottom: none;
  }

  .schedule li.closed {
    opacity: 0.5;
  }

  /* Services list */
  .services-list a {
    display: block;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
    font-size: 0.8rem;
    color: #637d96;
    gap: 1rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding: 2.5rem 1.25rem 2rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.3rem;
    }
  }
</style>
